#!/bin/bash
set -euo pipefail

RAW=$(git diff HEAD | claude -p "Output ONLY a single-line conventional commit message for this diff. No preamble, no explanation, only the commit message." --model "claude-opus-4-7")

COMMIT_MESSAGE=$(printf '%s\n' "$RAW" | grep -oEm1 '\w+([(][^)]+[)])?!?: [^`]+' || true)

if [ -z "$COMMIT_MESSAGE" ]; then
  echo "Error: could not extract a conventional commit message from model output:" >&2
  printf '%s\n' "$RAW" >&2
  exit 1
fi

printf '%s\n' "$COMMIT_MESSAGE"
